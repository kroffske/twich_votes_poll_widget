# Twitch application settings
# Create an app in Twitch Developer Console and add this redirect URI:
# http://localhost:3030/auth/callback
# Keep TWITCH_CLIENT_ID / TWITCH_CLIENT_SECRET empty in the example file:
# real values go into local `.env`, never into git.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3030/auth/callback

# Required for native Twitch poll events.
# channel:read:redemptions is only needed if ENABLE_REDEMPTIONS=true or REWARD_CHOICE_MAP_JSON is set.
# channel:manage:polls is required to create polls from the admin UI.
# NOTE: changing TWITCH_SCOPES requires a fresh login — hit /auth/logout then /auth/login
# so the new scope is actually included in the access token.
TWITCH_SCOPES=channel:read:polls channel:read:redemptions channel:manage:polls
# Optional: project target channel label shown in admin. Cosmetic only:
# it does not override the OAuth-authorized broadcaster used by Helix/EventSub.
TWITCH_TARGET_CHANNEL_LOGIN=

# Local server
PORT=3030
PUBLIC_BASE_URL=http://localhost:3030

# Local app token for `/admin`, `/overlay` and `/ws/overlay`.
# This is NOT a Twitch OAuth token and NOT your Twitch Client Secret.
# CLI replaces this example value with a random token on first init.
# Example OBS/Admin URL token: http://localhost:3030/overlay?token=YOUR_TOKEN&mode=scale&metric=votes
OVERLAY_TOKEN=admin-overlay-token-example

# Start local demo when there is no Twitch auth yet. Useful while styling OBS overlay.
DEMO_ON_START=true

# Subscribe to custom Channel Points reward redemptions.
# Native Twitch poll Channel Points votes work without this flag; this is for custom rewards only.
ENABLE_REDEMPTIONS=false

# Optional: map custom reward IDs to choice names for a points-only battle.
# Example: {"92af127c-7326-4483-a52b-b0da0be61c01":"Team Red","8d3...":"Team Blue"}
REWARD_CHOICE_MAP_JSON={}
REWARDS_POLL_TITLE=Channel Points Battle

# Optional overlay defaults; can be overridden in query params.
DEFAULT_OVERLAY_MODE=scale
DEFAULT_OVERLAY_METRIC=votes
